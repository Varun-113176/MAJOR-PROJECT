<mvc:View
    controllerName="com.varun.project2.fioriproject.controller.HR"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

<Page
    title="HR Login"
    class="sapUiResponsiveContentPadding">

    <content>

        <VBox height="100%"
              alignItems="Center"
              justifyContent="Center">

            <Panel width="360px"
                   class="sapUiSmallMargin"
                   backgroundDesign="Solid">

                <VBox alignItems="Center"
                      class="sapUiMediumMargin">

                    <!-- TITLE -->
                    <Title
                        text="Login"
                        level="H2"
                        class="sapUiSmallMarginBottom"/>

                    <!-- EMAIL -->
                    <Input
                        id="emailInput"
                        placeholder="HR Email"
                        type="Email"
                        width="100%"
                        required="true"
                        class="sapUiSmallMarginBottom"/>

                    <!-- PASSWORD -->
                    <Input
                        id="passwordInput"
                        placeholder="Password"
                        type="Password"
                        width="100%"
                        required="true"
                        class="sapUiSmallMarginBottom"/>

                    <!-- SHOW PASSWORD -->
                    <CheckBox
                        text="Show Password"
                        select="onShowPassword"
                        class="sapUiSmallMarginBottom"/>

                    <!-- LOGIN BUTTON -->
                    <Button
                        text="SIGN IN"
                        type="Emphasized"
                        width="100%"
                        press="onLogin"
                        class="sapUiMediumMarginBottom"/>

                    <!-- FORGOT PASSWORD -->
                    <Link
                        text="Forgot Password?"
                        press="onForgotPassword"
                        class="sapUiTinyMarginBottom"/>

                    <!-- SIGNUP -->
                    <HBox>
                        <Text text="Don't have an account? "/>
                        <Link
                            text="Sign up"
                            press="onOpenSignup"/>
                    </HBox>

                </VBox>

            </Panel>

        </VBox>

    </content>

</Page>

</mvc:View>