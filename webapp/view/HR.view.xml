<mvc:View
    controllerName="com.varun.project2.fioriproject.controller.HR"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

<Page id="_IDGenPage"
    title="HR Login"
    class="sapUiResponsiveContentPadding">

    <content>

        <VBox id="_IDGenVBox1" height="100%"
              alignItems="Center"
              justifyContent="Center">

            <Panel id="_IDGenPanel" width="360px"
                   class="sapUiSmallMargin"
                   backgroundDesign="Solid">

                <VBox id="_IDGenVBox4" alignItems="Center"
                      class="sapUiMediumMargin">

                    <!-- LOGIN TITLE -->
                    <Title id="_IDGenTitle"
                        text="Login"
                        level="H2"
                        class="sapUiSmallMarginBottom"/>

                    <!-- EMAIL -->
                    <Input
                        id="emailInput"
                        placeholder="Email"
                        type="Email"
                        width="100%"
                        required="true"
                        class="sapUiSmallMarginBottom"/>

                    <!-- PASSWORD -->
                    <Input
                        id="passwordInput"
                        placeholder="Password"
                        type="Password"
                        width="100%"
                        required="true"
                        class="sapUiSmallMarginBottom"/>

                    <!-- SHOW PASSWORD -->
                    <CheckBox id="_IDGenCheckBox"
                        text="Show Password"
                        select="onShowPassword"
                        class="sapUiSmallMarginBottom"/>

                    <!-- LOGIN BUTTON -->
                    <Button id="_IDGenButton2"
                        text="SIGN IN"
                        type="Emphasized"
                        width="100%"
                        press="onLogin"
                        class="sapUiMediumMarginBottom"/>

                    <!-- LINKS -->
                    <Text id="_IDGenText"
                        text="Forgot Username / Password?"
                        class="sapUiTinyMarginBottom"/>

                    <HBox id="_IDGenHBox1">
                        <Text id="_IDGenText1" text="Don't have an account? "/>
                        <Link id="_IDGenLink1"
                            text="Sign up"
                            press="onOpenSignup"/>
                    </HBox>

                </VBox>

            </Panel>

        </VBox>

    </content>

</Page>

</mvc:View>