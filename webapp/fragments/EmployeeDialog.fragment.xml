<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="dialogEmployee"
        title="Employee Details">

        <VBox class="sapUiMediumMargin">

            <!-- Name -->
            <Label text="Name"/>
            <Input id="inputName"/>

            <!-- Role -->
            <Label text="Role"/>
            <Input id="inputRole" class="sapUiSmallMarginTop"/>

            <!-- City -->
            <Label text="City"/>
            <Input id="inputCity" class="sapUiSmallMarginTop"/>

            <!-- Phone -->
            <Label text="Phone"/>
            <Input 
                id="inputPhone"
                type="Number"
                class="sapUiSmallMarginTop"/>

            <!-- Email -->
            <Label text="Email"/>
            <Input 
                id="inputEmail"
                type="Email"
                class="sapUiSmallMarginTop"/>

        </VBox>

        <beginButton>
            <Button
                text="Save"
                type="Emphasized"
                press="onAddEmployee"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press="onCloseDialog"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>