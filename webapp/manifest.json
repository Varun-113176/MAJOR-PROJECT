{
  "_version": "1.82.0",

  "sap.app": {
    "id": "com.varun.project2.fioriproject",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",

    "applicationVersion": {
      "version": "0.0.1"
    },

    "dataSources": {
      "mainService": {
        "uri": "/V2/Northwind/Northwind.svc/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0"
        }
      }
    }
  },

  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },

  "sap.ui5": {

    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.viz": {}
      }
    },

    "models": {

      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.varun.project2.fioriproject.i18n.i18n",
          "supportedLocales": ["en"],
          "fallbackLocale": "en"
        }
      },

      "": {
        "type": "sap.ui.model.odata.v2.ODataModel",
        "dataSource": "mainService",
        "settings": {
          "defaultBindingMode": "TwoWay",
          "useBatch": true
        }
      }

    },

    "routing": {

      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.varun.project2.fioriproject.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },

      "routes": [
        {
          "name": "Main",
          "pattern": "",
          "target": "Main"
        },
        {
          "name": "HR",
          "pattern": "hr",
          "target": "HR"
        },
        {
          "name": "Admin",
          "pattern": "admin",
          "target": "Admin"
        },
        {
          "name": "Employee",
          "pattern": "employee/{empName}",
          "target": "Employee"
        },
        {
          "name": "Analytics",
          "pattern": "analytics/{empName}",
          "target": "Analytics"
        }
      ],

      "targets": {
        "Main": {
          "viewName": "Main"
        },
        "HR": {
          "viewName": "HR"
        },
        "Admin": {
          "viewName": "Admin"
        },
        "Employee": {
          "viewName": "Employee"
        },
        "Analytics": {
          "viewName": "Analytics"
        }
      }

    },

    "rootView": {
      "viewName": "com.varun.project2.fioriproject.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    }

  }
}